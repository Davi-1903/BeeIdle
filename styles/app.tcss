#sidebar-container {
    width: 0;
    height: 1fr;
}

#sidebar-container.open {
    width: 2fr;
    height: 1fr;
    padding: 1;
}

#actions-content {
    height: auto;
    margin-bottom: 1;
}

#actions-content #create-btn {
    margin-right: 1;
}

#code-container {
    width: 8fr;
    height: 100%;
    padding-top: 1;
}

.code:focus {
    border: none;
}

OpenDirectoryModal {
    padding: 1;
}

#open-directory-btn {
    width: 100%;
}